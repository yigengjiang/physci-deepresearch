# ─────────────────────────────────────────────────────────────────────────────
# PhySciBench evaluation — environment variables
# Copy to `.env` and fill in. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Judge model (REQUIRED for eval/score.py) ────────────────────────────────
# OpenAI-compatible endpoint used as the LLM-as-judge for rubric/atomic grading.
# IMPORTANT: long-form/rubric grading uses structured outputs (response_format
# with a nested JSON schema). Use a GPT-class model that supports it; some
# Gemini-compatible proxies reject the nested schema with HTTP 400 (see README).
JUDGE_LLM_API_KEY=sk-your-judge-api-key
JUDGE_LLM_BASE_URL=https://api.openai.com/v1/
JUDGE_LLM_MODEL=gpt-5.2
JUDGE_LLM_TYPE=chat.completions

# ── e2b sandbox (OPTIONAL — only the `code-generation` task category) ────────
# If unset, code-generation items are gracefully skipped and all other task
# types still score normally.
# E2B_API_KEY=e2b_your-api-key
